# ===========================================
# BLADEOPS — Environment Variables
# ===========================================
# Copy this file to .env and fill in values

# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL / Supabase)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bladeops
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bladeops
DB_USER=postgres
DB_PASSWORD=postgres

# JWT
JWT_SECRET=bladeops_jwt_secret_2024_offshore
JWT_EXPIRES_IN=24h

# Admin credentials (initial setup)
ADMIN_EMAIL=admin@bladeops.ao
ADMIN_PASSWORD=Admin@2026

# Supabase (if using Supabase instead of raw PG)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_KEY=your_service_key

# PDF
PDF_OUTPUT_DIR=./storage/reports

# Company Info (for reports)
COMPANY_NAME=BladeOps
COMPANY_CLIENT=Chevron PSVM Angola
